{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "o-storytelling-app",
  "version": "0.1.0",
  "identifier": "com.tauri-app.o-storytelling-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8550",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "o-storytelling-app",
        "width": 1280,
        "height": 720,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$PICTURE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
