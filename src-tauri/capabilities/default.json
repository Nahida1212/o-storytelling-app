{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-confirm",
    "fs:allow-copy-file",
    "fs:allow-read-file",
    "fs:allow-log-write",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**",          
        "$DOCUMENT/**",         
        "$DESKTOP/**",
        "$PICTURE/**"
      ]
    }
  ]
}
